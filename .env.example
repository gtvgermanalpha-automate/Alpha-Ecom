# ─── CMS admin auth ───────────────────────────────────────
# Password to log in at /admin
ADMIN_PASSWORD=
# Long random string used to sign the admin session cookie (e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=

# ─── Publishing target (GitHub) ───────────────────────────
# A token that can READ/WRITE this repo. Two options:
#   1. Classic PAT (scope: repo) from an account with push access — works even
#      when the repo is owned by a *different* user. Simplest, recommended here.
#   2. Fine-grained PAT — ONLY reaches repos owned by its "resource owner". Since
#      this repo is owned by the USER "gtvgermanalpha-automate" (not an org), the
#      token must be created while signed in AS that account, with this repo
#      selected and Contents: Read and write. A fine-grained PAT from any other
#      account returns 404 on every call → "branch not found".
# Paste with NO trailing spaces/newlines.
GITHUB_TOKEN=
# "owner/name" exactly, e.g. gtvgermanalpha-automate/Alpha-Ecom (case-sensitive owner)
GITHUB_REPO=
# Published branch the host builds (Publish merges into this)
GITHUB_BRANCH=main
# Draft branch CMS edits commit to (auto-created; host must NOT build it)
GITHUB_DRAFT_BRANCH=cms-draft

# ─── Site ────────────────────────────────────────────────
# Absolute production URL (used for metadata / sitemap / OG)
NEXT_PUBLIC_SITE_URL=

# Notes:
# - Without GITHUB_* the CMS runs in LOCAL mode: edits write straight to the
#   JSON files on disk (great for local editing). Set GITHUB_* on Vercel to use
#   the draft → publish workflow in production.
# - Without ADMIN_* the /admin login is disabled (shows a "not configured" notice).
